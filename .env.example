# Anthropic (LLM)
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI (embeddings — Anthropic's recommended provider)
# Get a key at https://www.voyageai.com — free tier covers 200M tokens.
VOYAGE_API_KEY=pa-...

# Neon Postgres (pgvector). Use the pooled connection string from the
# Neon console — Dashboard → Connection Details → "Pooled connection".
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Public site URL used for Open Graph / Twitter card metadata. Set this
# in Vercel to your production URL (e.g. https://gmaps.yourdomain.dev).
# Leave unset for local dev — falls back to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=
